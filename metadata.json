{
  "name": "attachmentgenie-traefik2",
  "version": "2.0.0-rc0",
  "author": "attachmentgenie",
  "summary": "Puppet module for Traefik2",
  "license": "Apache-2.0",
  "source": "https://github.com/attachmentgenie/attachmentgenie-traefik2.git",
  "dependencies": [
    {
      "name": "puppetlabs/stdlib",
      "version_requirement": ">= 9.2.0 < 11.0.0"
    },
    {
      "name": "puppet/systemd",
      "version_requirement": ">= 7.1.0 < 10.0.0"
    },
    {
      "name": "puppet/archive",
      "version_requirement": ">= 2.2.0 < 9.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Rocky",
      "operatingsystemrelease": [
        "8",
        "9"
      ]
    },
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": [
        "11",
        "12"
      ]
    },
    {
      "operatingsystem": "Ubuntu",
      "operatingsystemrelease": [
        "24.04",
        "26.04"
      ]
    }
  ],
  "requirements": [
    {
      "name": "openvox",
      "version_requirement": ">= 8.19.0 < 9.0.0"
    }
  ]
}
